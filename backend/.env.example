# ContractorHub Backend — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.

# Required — app will crash without these
DATABASE_URL=postgresql+asyncpg://appuser:apppassword@localhost:5432/contractorhub
JWT_SECRET_KEY=change-me-to-a-random-secret-at-least-32-chars

# Optional
REDIS_URL=redis://localhost:6379/0
DEBUG=false
CORS_ORIGINS=http://localhost:3000
